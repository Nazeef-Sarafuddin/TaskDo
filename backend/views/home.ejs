<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>TODO</title>
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/stylesheets/home.css">
</head>
<body>

    <div class="noise"></div>

    <main>
        <div class="hero">

            <div class="badge">v1.0 — Task Manager</div>

            <h1>
                <span class="line">Get things</span>
                <span class="line accent">done.</span>
            </h1>

            <p class="sub">A clean, fast space to capture your tasks,<br>stay organised, and move forward.</p>

            <div class="cta-group">
                <a href="/todo" class="btn-primary">
                    View My Tasks
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="5" y1="12" x2="19" y2="12"/>
                        <polyline points="12 5 19 12 12 19"/>
                    </svg>
                </a>
                <a href="/todo/new" class="btn-secondary">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
                        <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
                    </svg>
                    Add a Task
                </a>
            </div>

        </div>

        <div class="preview">
            <div class="preview-label">Your workspace</div>
            <div class="card-stack">
                <div class="mock-card" style="--d: 0.05s">
                    <span class="mock-index">01</span>
                    <span class="mock-title">Design the homepage</span>
                    <div class="mock-dot done"></div>
                </div>
                <div class="mock-card" style="--d: 0.12s">
                    <span class="mock-index">02</span>
                    <span class="mock-title">Connect MongoDB</span>
                    <div class="mock-dot done"></div>
                </div>
                <div class="mock-card" style="--d: 0.19s">
                    <span class="mock-index">03</span>
                    <span class="mock-title">Style the EJS views</span>
                    <div class="mock-dot pending"></div>
                </div>
                <div class="mock-card" style="--d: 0.26s">
                    <span class="mock-index">04</span>
                    <span class="mock-title">Deploy to production</span>
                    <div class="mock-dot pending"></div>
                </div>
            </div>
        </div>
    </main>

    <footer>
        <span>Built with Node · Express · MongoDB · EJS</span>
    </footer>

</body>
</html>
