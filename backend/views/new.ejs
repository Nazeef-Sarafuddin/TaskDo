<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>New Task</title>
    <link rel="stylesheet" href="/stylesheets/new.css">
</head>
<body>
<div class="container">

    <header>
        <span class="label">New Entry</span>
        <h1>Add Task</h1>
    </header>

    <div class="form-card">
        <form action="/todo" method="post">

            <div class="field">
                <label for="title">Task Name</label>
                <input type="text" name="task[title]" id="title" placeholder="e.g. Buy groceries">
            </div>

            <div class="field-divider"></div>

            <div class="field">
                <label for="description">Description</label>
                <input type="text" name="task[description]" id="description" placeholder="e.g. Milk, eggs, bread...">
            </div>

            <div class="field-divider"></div>

            <div class="field">
                <label for="createdAt">Date</label>
                <input type="date" name="task[createdAt]" id="createdAt">
            </div>

            <div class="actions">
                <a href="/todo" class="btn-back">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="15 18 9 12 15 6"/>
                    </svg>
                    Back to Tasks
                </a>
                <button type="submit" class="btn-submit">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
                        <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
                    </svg>
                    Add Task
                </button>
            </div>

        </form>
    </div>

</div>
</body>
</html>
